        "create_time": 1709200005,
        "content": {
          "parts": [
            "How do I configure a Boundary worker locally?"
          ]
        }
      }
    },
    "b3": {
      "id": "b3",
      "parent": "b2",
      "children": [],
      "message": {
        "author": {
          "role": "assistant"
        },
        "create_time": 1709200010,
        "content": {
          "parts": [
            "A Boundary worker configuration might look like this:",
            "```hcl",
            "listener \"tcp\" {",
            "  address = \"0.0.0.0:9202\"",
            "  purpose = \"proxy\"",
            "}",
            "",
            "worker {",
            "  auth_storage_path = \"/boundary/worker\"",
            "}",
            "```"
          ]
        }
      }
    },
    "b4": {
      "id": "b4",
      "parent": "b2",
      "children": [],
      "message": {
        "author": {
          "role": "assistant"
        },
        "create_time": 1709200015,
        "content": {
          "parts": [
            "Alternatively you can run a worker container and mount the config."
          ]
        }
      }
    }
  }
}